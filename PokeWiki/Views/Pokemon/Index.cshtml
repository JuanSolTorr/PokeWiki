@model IEnumerable<PokeWiki.Web.Models.ViewModels.PokemonListVM>

@{
    ViewData["Title"] = "National Pokédex";
}

<div class="space-y-6">
    <div class="border-l-8 border-poke-red pl-6 py-2 bg-white dark:bg-gray-800 shadow-sm transition-colors duration-300">
        <h1 class="text-4xl font-black uppercase tracking-tighter text-poke-dark dark:text-white transition-colors duration-300">General Index</h1>
    </div>

    <div id="pokemon-index-content">
        <partial name="_PokemonIndexContent" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        PokeWikiAjax.initAjaxListNavigation({
            containerId: 'pokemon-index-content',
            linkClass: 'js-pokemon-ajax-link',
            formClass: 'js-pokemon-ajax-form'
        });
    </script>
}