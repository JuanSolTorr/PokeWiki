@model IEnumerable<PokeWiki.Web.Models.ViewModels.PokemonListVM>

@{
    ViewData["Title"] = "Pokédex Nacional";
}

<div class="space-y-6">
    <div class="border-l-8 border-poke-red pl-6 py-2 bg-white shadow-sm">
        <h1 class="text-4xl font-black uppercase tracking-tighter text-poke-dark">Índice General</h1>
        <p class="text-gray-400 font-bold text-xs tracking-[0.3em] uppercase">Sincronizado con Base de Datos SQL Server 2026</p>
    </div>

    <div class="bg-poke-dark p-4 flex flex-col md:flex-row gap-4 items-center justify-between">
        <div class="relative w-full md:w-96">
            <input type="text" id="pokeSearch" placeholder="BUSCAR NOMBRE O ID..."
                   class="w-full bg-gray-800 border-none text-white placeholder-gray-500 py-2 px-4 focus:ring-2 focus:ring-poke-red uppercase text-xs font-bold tracking-widest" />
        </div>
        <div class="text-white text-[10px] font-bold uppercase tracking-widest">
            Registros Totales: <span class="text-poke-red text-lg ml-2">@Model.Count()</span>
        </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-1" id="pokeGrid">
        @foreach (var pokemon in Model)
        {
            <a asp-action="Details" asp-route-id="@pokemon.Id" class="poke-card bg-white border border-gray-100 p-4 group hover:bg-poke-red transition-all duration-200">
                <div class="relative">
                    <span class="text-[10px] font-black text-gray-200 group-hover:text-white/30 transition-colors">#@pokemon.Id.ToString("D4")</span>

                    <div class="aspect-square flex items-center justify-center py-4">
                        <img src="@pokemon.ImagenUrl"
                             alt="@pokemon.Nombre"
                             loading="lazy"
                             class="w-24 h-24 object-contain group-hover:scale-110 transition-transform duration-300"
                             onerror="this.src='/images/no-sprite.png'" />
                    </div>

                    <div class="text-center mt-2">
                        <h3 class="text-xs font-black uppercase truncate text-poke-dark group-hover:text-white tracking-tighter">
                            @pokemon.Nombre
                        </h3>
                        <div class="flex justify-center gap-1 mt-2">
                            @foreach (var tipo in pokemon.Tipos)
                            {
                                <span class="w-1.5 h-1.5 rounded-full bg-gray-200 group-hover:bg-white/50"></span>
                            }
                        </div>
                    </div>
                </div>
            </a>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Filtrado Frontend ultra-rápido
        document.getElementById('pokeSearch').addEventListener('input', function (e) {
            const val = e.target.value.toLowerCase();
            const cards = document.querySelectorAll('.poke-card');
            cards.forEach(card => {
                const text = card.innerText.toLowerCase();
                card.style.display = text.includes(val) ? 'block' : 'none';
            });
        });
    </script>
}