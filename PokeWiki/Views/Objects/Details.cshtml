@model PokeWiki.Web.Models.ViewModels.ObjetoDetalleVM

@{
    ViewData["Title"] = Model.Nombre;
}

<div class="space-y-6 max-w-5xl mx-auto pb-12">
    <div class="bg-poke-dark dark:bg-black p-6 flex flex-col md:flex-row items-center gap-8 shadow-sm border-l-8 border-poke-red text-white uppercase tracking-widest transition-colors duration-300 rounded">
        <div class="relative z-10 bg-white/5 p-4 border border-white/10 rounded">
            <img src="@Model.ImagenUrl" alt="@Model.Nombre" class="w-32 h-32 object-contain drop-shadow-2xl" onerror="this.src='/images/no-sprite.png'" />
        </div>

        <div class="text-center md:text-left flex-grow z-10">
            <p class="text-poke-gold text-xs font-black mb-2">@Model.Categoria</p>
            <h1 class="text-4xl font-black uppercase tracking-tighter mb-3">@Model.Nombre</h1>
            <div class="inline-flex items-center px-2.5 py-1 rounded bg-white text-poke-dark text-[10px] font-black uppercase tracking-widest">
                Rarity: @Model.Rareza
            </div>
        </div>

        <div class="z-10">
            <a asp-action="Index" class="bg-gray-800 dark:bg-gray-900 text-white px-6 py-3 text-[10px] font-black border border-gray-700 dark:border-gray-800 hover:bg-poke-red dark:hover:bg-red-700 transition-colors rounded">BACK</a>
        </div>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border-l-4 border-poke-red p-6 transition-colors duration-300">
        <h2 class="text-lg font-black uppercase tracking-widest text-poke-dark dark:text-white mb-3">Item description</h2>
        <p class="text-sm font-semibold text-gray-600 dark:text-gray-300 leading-relaxed">@Model.Descripcion</p>

        <h3 class="text-sm font-black uppercase tracking-widest text-poke-dark dark:text-white mt-6 mb-2">Effect</h3>
        <p class="text-sm font-semibold text-gray-600 dark:text-gray-300 leading-relaxed">@Model.Efecto</p>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border-l-4 border-poke-red p-0 overflow-hidden transition-colors duration-300">
        <div class="bg-poke-dark dark:bg-black p-4 border-b-4 border-poke-red dark:border-red-700">
            <h2 class="text-white font-black uppercase tracking-widest text-xs">Where to find by generation</h2>
        </div>

        @if (!Model.DondeSeConsiguePorGeneracion.Any())
        {
            <div class="p-8 text-center text-gray-400 dark:text-gray-500 uppercase text-xs font-bold tracking-widest">
                No availability data by generation for this item.
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left text-[11px] font-bold uppercase tracking-wider text-poke-dark dark:text-gray-200">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                            <th class="p-4">Generation</th>
                            <th class="p-4 text-right">Index</th>
                            <th class="p-4">Games</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fila in Model.DondeSeConsiguePorGeneracion)
                        {
                            <tr class="border-t border-gray-100 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/60 transition-colors">
                                <td class="p-4 text-poke-red dark:text-red-400 font-black">@fila.Generacion</td>
                                <td class="p-4 text-right">@fila.IndiceJuego</td>
                                <td class="p-4 normal-case font-semibold text-gray-700 dark:text-gray-300">@fila.Juegos</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
