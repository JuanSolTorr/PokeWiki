@model IEnumerable<NugetPokeWiki.DTOs.ObjetoDto>
@{
    ViewData["Title"] = "Items";
}

<div class="space-y-6">
    <div class="border-l-8 border-poke-red pl-6 py-2 bg-white dark:bg-gray-800 shadow-sm transition-colors duration-300">
        <h1 class="text-4xl font-black uppercase tracking-tighter text-poke-dark dark:text-white transition-colors">Item Inventory</h1>
    </div>

    <div id="objects-index-content">
        <partial name="_ObjectsIndexContent" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        PokeWikiAjax.initAjaxListNavigation({
            containerId: 'objects-index-content',
            linkClass: 'js-objects-ajax-link',
            formClass: 'js-objects-ajax-form'
        });
    </script>
}
