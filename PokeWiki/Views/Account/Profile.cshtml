@{
    ViewData["Title"] = "Centro de Entrenador";
    var userName = ViewData["UserName"]?.ToString();
    var email = ViewData["Email"]?.ToString();
    bool isDark = Context.Request.Cookies["theme"] == "dark";
}

<div class="max-w-4xl mx-auto mt-10">
    <!-- Cabecera del Perfil -->
    <div class="bg-poke-dark dark:bg-black text-white rounded-t-lg p-8 shadow-xl border-b-4 border-poke-red transition-colors duration-300">
        <div class="flex items-center gap-6">
            <div class="w-24 h-24 bg-white dark:bg-gray-800 rounded-full flex items-center justify-center border-4 border-poke-gold shadow-lg shadow-black/50 transition-colors">
               <span class="text-4xl font-black text-poke-dark dark:text-gray-200">@userName?.FirstOrDefault()</span>
            </div>
            <div>
                <h1 class="text-4xl font-black uppercase tracking-tighter">@userName</h1>
                <p class="text-poke-gold font-bold flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                    ID de Entrenador Activo
                </p>
                <p class="text-gray-400 text-sm mt-1">@email</p>
            </div>
        </div>
    </div>

    <!-- Contenido Principal: Ajustes -->
    <div class="bg-white dark:bg-gray-800 rounded-b-lg p-8 shadow-xl border-x border-b border-gray-200 dark:border-gray-700 transition-colors duration-300">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            
            <!-- Columna Izquierda: Preferencias -->
            <div class="space-y-8">
                <div>
                    <h3 class="text-xl font-black uppercase border-b-2 border-poke-gold pb-2 mb-4 text-poke-dark dark:text-gray-100 transition-colors">Apariencia de la Pokédex</h3>
                    <form asp-action="ChangeTheme" method="post" class="bg-gray-50 dark:bg-gray-700 p-4 rounded border border-gray-200 dark:border-gray-600 transition-colors">
                        <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 font-semibold transition-colors">Selecciona la variante de tu interfaz:</p>
                        <div class="flex gap-4">
                            <label class="flex items-center gap-2 cursor-pointer group">
                                <input type="radio" name="theme" value="light" checked="@(!isDark)" class="text-poke-red focus:ring-poke-red bg-white dark:bg-gray-600">
                                <span class="group-hover:text-poke-red font-bold text-sm dark:text-gray-200 transition-colors">Tema Claro</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer group">
                                <input type="radio" name="theme" value="dark" checked="@isDark" class="text-poke-red focus:ring-poke-red bg-white dark:bg-gray-600">
                                <span class="group-hover:text-poke-red font-bold text-sm dark:text-gray-200 transition-colors">Tema Oscuro</span>
                            </label>
                        </div>
                        <button type="submit" class="mt-4 text-xs font-bold bg-poke-dark dark:bg-black text-white px-4 py-2 uppercase rounded hover:bg-gray-800 dark:hover:bg-gray-900 transition mt-6">
                            Guardar Preferencia
                        </button>
                    </form>
                </div>
            </div>

            <!-- Columna Derecha: Seguridad -->
            <div class="space-y-8">
                <!-- Cambiar Contraseña -->
                <div>
                    <h3 class="text-xl font-black uppercase border-b-2 border-poke-red pb-2 mb-4 text-poke-dark dark:text-gray-100 transition-colors">Seguridad</h3>
                    
                    @if (ViewBag.PasswordSuccess != null)
                    {
                        <div class="bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 p-3 rounded text-sm font-bold mb-4 border border-green-300 dark:border-green-800 transition-colors">@ViewBag.PasswordSuccess</div>
                    }
                    @if (ViewBag.PasswordError != null)
                    {
                        <div class="bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 p-3 rounded text-sm font-bold mb-4 border border-red-300 dark:border-red-800 transition-colors">@ViewBag.PasswordError</div>
                    }

                    <form asp-action="ChangePassword" method="post" class="bg-gray-50 dark:bg-gray-700 p-4 rounded border border-gray-200 dark:border-gray-600 flex flex-col gap-3 transition-colors">
                        <div>
                            <label class="block text-xs font-bold uppercase text-gray-500 dark:text-gray-400 mb-1 transition-colors">Contraseña Actual</label>
                            <input type="password" name="currentPassword" required class="w-full text-sm border p-2 rounded focus:border-poke-red focus:ring-0 outline-none bg-white dark:bg-gray-600 dark:border-gray-500 dark:text-white transition-colors" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase text-gray-500 dark:text-gray-400 mb-1 transition-colors">Nueva Contraseña</label>
                            <input type="password" name="newPassword" required class="w-full text-sm border p-2 rounded focus:border-poke-red focus:ring-0 outline-none bg-white dark:bg-gray-600 dark:border-gray-500 dark:text-white transition-colors" />
                        </div>
                        <button type="submit" class="self-start text-xs font-bold bg-poke-red text-white px-4 py-2 uppercase rounded hover:bg-red-700 transition">
                            Actualizar Clave
                        </button>
                    </form>
                </div>

                <!-- Zona Peligrosa -->
                <div>
                    <h3 class="text-xl font-black uppercase border-b-2 border-red-600 pb-2 mb-4 text-red-600 dark:text-red-500 transition-colors">Zona de Riesgo</h3>
                    
                    @if (ViewBag.DeleteError != null)
                    {
                        <div class="bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 p-3 rounded text-sm font-bold mb-4 border border-red-300 dark:border-red-800 transition-colors">@ViewBag.DeleteError</div>
                    }

                    <div class="bg-red-50 dark:bg-red-950/30 p-4 rounded border border-red-200 dark:border-red-900/50 transition-colors">
                        <p class="text-xs text-red-700 dark:text-red-400 font-bold mb-3 transition-colors">Borrar cuenta de entrenador. Irreversible.</p>
                        
                        <form asp-action="DeleteAccount" method="post" class="flex flex-col gap-3" onsubmit="return confirm('¿Estás SEGURO de querer borrar tu registro de entrenador para siempre? Esto eliminará todos tus datos de la liga Pokémon.');">
                            <div>
                                <label class="block text-[10px] font-black uppercase text-red-600 dark:text-red-500 mb-1 transition-colors">Escribe tu contraseña para confirmar</label>
                                <input type="password" name="confirmPassword" required class="w-full text-sm border border-red-300 dark:border-red-800 p-2 rounded focus:border-red-500 focus:ring-0 outline-none bg-white dark:bg-gray-800 dark:text-white transition-colors" />
                            </div>
                            <button type="submit" class="self-start text-xs font-black border-2 border-red-600 dark:border-red-500 text-red-600 dark:text-red-500 px-4 py-2 uppercase rounded hover:bg-red-600 hover:text-white transition">
                                Revocar Licencia
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
