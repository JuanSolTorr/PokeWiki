@{
    ViewData["Title"] = "Registro de Entrenador";
}

<div class="max-w-md mx-auto mt-20 bg-white p-8 border-t-8 border-poke-red shadow-2xl rounded-lg">
    <h2 class="text-3xl font-black uppercase tracking-tighter mb-6 text-poke-dark">Nuevo Entrenador</h2>

    @if (ViewBag.Error != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 text-sm font-bold">
            @ViewBag.Error
        </div>
    }

    <form asp-controller="Account" asp-action="Register" method="post" class="space-y-4">
        <div>
            <label class="block text-xs font-bold uppercase text-gray-400 mb-1">Nombre de Usuario</label>
            <input name="username" type="text" class="w-full border-2 border-gray-200 p-3 focus:border-poke-red focus:ring-0 outline-none rounded transition-colors" required />
        </div>
        <div>
            <label class="block text-xs font-bold uppercase text-gray-400 mb-1">Email</label>
            <input name="email" type="email" class="w-full border-2 border-gray-200 p-3 focus:border-poke-red focus:ring-0 outline-none rounded transition-colors" required />
        </div>
        <div>
            <label class="block text-xs font-bold uppercase text-gray-400 mb-1">Contraseña</label>
            <input name="password" type="password" class="w-full border-2 border-gray-200 p-3 focus:border-poke-red focus:ring-0 outline-none rounded transition-colors" required />
        </div>
        <button type="submit" class="w-full bg-poke-dark text-white font-black py-4 uppercase hover:bg-poke-red transition-colors rounded mt-4">
            Obtener Licencia
        </button>
    </form>
</div>