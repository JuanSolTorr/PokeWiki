@model IEnumerable<NugetPokeWiki.DTOs.MovimientosDto>
@{
    ViewData["Title"] = "Technical Machine Index";
}

<div class="space-y-6">
    <div class="border-l-8 border-poke-red pl-6 py-2 bg-white dark:bg-gray-800 shadow-sm transition-colors duration-300">
        <h1 class="text-4xl font-black uppercase tracking-tighter text-poke-dark dark:text-white transition-colors">Technical Machine Registry (TM)</h1>
    </div>

    <div id="moves-index-content">
        <partial name="_MovesIndexContent" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        PokeWikiAjax.initAjaxListNavigation({
            containerId: 'moves-index-content',
            linkClass: 'js-moves-ajax-link',
            formClass: 'js-moves-ajax-form'
        });
    </script>
}