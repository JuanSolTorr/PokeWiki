@model NugetPokeWiki.DTOs.MovimientosDto

@{
    ViewData["Title"] = "Technical Record: " + Model.movimiento;
    var pokemonList = ViewBag.PokemonCompatibles as IEnumerable<NugetPokeWiki.DTOs.PokemonCompatibleMoveDto>;
}

<div class="space-y-6 max-w-6xl mx-auto pb-12">
    <div class="bg-poke-dark dark:bg-black p-6 flex flex-col md:flex-row items-center gap-8 shadow-sm border-l-8 border-poke-red relative overflow-hidden text-white uppercase tracking-widest transition-colors duration-300">
        <div class="absolute -right-10 -top-10 opacity-5 text-9xl font-black italic text-white dark:text-gray-500">
            @Model.mt_numero
        </div>

        <div class="text-center md:text-left flex-grow z-10">
            <span class="text-poke-red dark:text-red-400 font-black text-sm block mb-2 transition-colors">@Model.mt_numero?.ToUpper()</span>
            <h1 class="text-5xl font-black uppercase tracking-tighter mb-4 text-white">@Model.movimiento</h1>
            <div class="flex flex-wrap justify-center md:justify-start gap-4">
                <span class="px-4 py-1 bg-white text-poke-dark text-[10px] font-black shadow-md">
                    TYPE: @Model.tipo
                </span>
                <span class="px-4 py-1 bg-gray-800 text-white text-[10px] font-black border-b-2 border-poke-red dark:border-red-600 transition-colors">
                    CLASS: @Model.clase_daño
                </span>
            </div>
        </div>

        <div class="z-10">
            <a asp-action="Index" class="bg-gray-800 dark:bg-gray-900 text-white px-6 py-3 text-[10px] font-black border border-gray-700 dark:border-gray-800 hover:bg-poke-red dark:hover:bg-red-700 transition-all rounded">
                BACK TO INDEX
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white dark:bg-gray-800 p-6 shadow-sm border-t-4 border-poke-dark dark:border-gray-600 text-center transition-colors duration-300 rounded">
            <p class="text-[10px] font-bold text-gray-400 dark:text-gray-400 uppercase tracking-widest mb-1 transition-colors">Power</p>
            <p class="text-4xl font-black text-poke-dark dark:text-white transition-colors">@(Model.power > 0 ? Model.power.ToString() : "—")</p>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 shadow-sm border-t-4 border-poke-dark dark:border-gray-600 text-center transition-colors duration-300 rounded">
            <p class="text-[10px] font-bold text-gray-400 dark:text-gray-400 uppercase tracking-widest mb-1 transition-colors">Accuracy</p>
            <p class="text-4xl font-black text-poke-dark dark:text-white transition-colors">@(Model.accuracy > 0 ? Model.accuracy.ToString() + "%" : "—")</p>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 shadow-sm border-t-4 border-poke-dark dark:border-gray-600 text-center transition-colors duration-300 rounded">
            <p class="text-[10px] font-bold text-gray-400 dark:text-gray-400 uppercase tracking-widest mb-1 transition-colors">Max PP</p>
            <p class="text-4xl font-black text-poke-dark dark:text-white transition-colors">@Model.pp</p>
        </div>
    </div>

    <div class="bg-white dark:bg-gray-800 shadow-xl border-t-4 border-poke-red dark:border-red-600 transition-colors duration-300 rounded">
        <div class="bg-poke-dark dark:bg-black p-4 flex justify-between items-center transition-colors rounded-t">
            <h2 class="text-white dark:text-gray-100 font-black uppercase tracking-widest text-[10px] transition-colors">Species compatible with this technique</h2>
            <span class="text-poke-red dark:text-red-500 font-black text-xl transition-colors">@(pokemonList?.Count() ?? 0)</span>
        </div>
        <div class="p-6">
            @if (pokemonList != null && pokemonList.Any())
            {
                <div class="grid grid-cols-3 sm:grid-cols-5 md:grid-cols-8 lg:grid-cols-10 gap-3">
                    @foreach (var pk in pokemonList)
                    {
                        <a asp-controller="Pokemon" asp-action="Details" asp-route-id="@pk.Id"
                           class="group flex flex-col items-center p-2 bg-gray-50 dark:bg-gray-700 hover:bg-white dark:hover:bg-gray-600 border border-transparent hover:border-poke-red dark:hover:border-red-500 transition-all rounded shadow-sm">
                            <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/@(pk.Id).png"
                                 class="w-14 h-14 object-contain group-hover:scale-110 transition-transform drop-shadow" />
                            <p class="mt-1 text-[8px] font-black uppercase text-center text-gray-500 dark:text-gray-300 group-hover:text-poke-red dark:group-hover:text-red-400 truncate w-full transition-colors">
                                @pk.Nombre
                            </p>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="py-12 text-center text-gray-300 dark:text-gray-600 font-bold uppercase text-[10px] tracking-widest italic transition-colors">
                    No compatibility records found.
                </div>
            }
        </div>
    </div>
</div>